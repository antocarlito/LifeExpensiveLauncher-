<Application x:Class="LifeExpensiveLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Couleurs LifeExpensive (identiques au site web) -->
        <Color x:Key="IndigoColor">#2200CC</Color>
        <Color x:Key="IndigoDarkColor">#1A009E</Color>
        <Color x:Key="IndigoLightColor">#3311DD</Color>
        <Color x:Key="CyanColor">#00BBDD</Color>
        <Color x:Key="CyanLightColor">#33CCEE</Color>
        <Color x:Key="OrangeColor">#FF8C00</Color>
        <Color x:Key="OrangeLightColor">#FFAA33</Color>
        <Color x:Key="BgDarkColor">#0D0D1A</Color>
        <Color x:Key="BgMediumColor">#131328</Color>
        <Color x:Key="BgLightColor">#1C1C3A</Color>
        <Color x:Key="BgCardColor">#1A1A35</Color>
        <Color x:Key="TextColor">#E0E0E0</Color>
        <Color x:Key="TextDimColor">#888899</Color>
        <Color x:Key="SuccessColor">#00C853</Color>
        <Color x:Key="DangerColor">#FF1744</Color>

        <SolidColorBrush x:Key="IndigoBrush" Color="{StaticResource IndigoColor}"/>
        <SolidColorBrush x:Key="IndigoDarkBrush" Color="{StaticResource IndigoDarkColor}"/>
        <SolidColorBrush x:Key="IndigoLightBrush" Color="{StaticResource IndigoLightColor}"/>
        <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanColor}"/>
        <SolidColorBrush x:Key="CyanLightBrush" Color="{StaticResource CyanLightColor}"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource OrangeColor}"/>
        <SolidColorBrush x:Key="OrangeLightBrush" Color="{StaticResource OrangeLightColor}"/>
        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDarkColor}"/>
        <SolidColorBrush x:Key="BgMediumBrush" Color="{StaticResource BgMediumColor}"/>
        <SolidColorBrush x:Key="BgLightBrush" Color="{StaticResource BgLightColor}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

        <!-- Gradient Indigo->Cyan (comme le site) -->
        <LinearGradientBrush x:Key="GradientIndigoCyan" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="{StaticResource IndigoColor}" Offset="0"/>
            <GradientStop Color="{StaticResource CyanColor}" Offset="1"/>
        </LinearGradientBrush>

        <!-- Gradient Indigo->Cyan->Orange (barre du site) -->
        <LinearGradientBrush x:Key="GradientFull" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="{StaticResource IndigoColor}" Offset="0"/>
            <GradientStop Color="{StaticResource CyanColor}" Offset="0.5"/>
            <GradientStop Color="{StaticResource OrangeColor}" Offset="1"/>
        </LinearGradientBrush>

        <!-- Style bouton JOUER (gradient indigo) -->
        <Style x:Key="PlayButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="50,16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource IndigoColor}" Offset="0"/>
                                    <GradientStop Color="{StaticResource IndigoDarkColor}" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource IndigoColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{StaticResource IndigoLightColor}" Offset="0"/>
                                            <GradientStop Color="{StaticResource IndigoColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton secondaire -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252550"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style bouton cyan -->
        <Style x:Key="CyanButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource CyanColor}" Offset="0"/>
                                    <GradientStop Color="#009BB8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{StaticResource CyanLightColor}" Offset="0"/>
                                            <GradientStop Color="{StaticResource CyanColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ProgressBar gradient -->
        <Style x:Key="ModernProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#1C1C3A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" CornerRadius="3" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="{StaticResource IndigoColor}" Offset="0"/>
                                            <GradientStop Color="{StaticResource CyanColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton fermer (rouge) -->
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton fenetre (minimize, etc.) -->
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333355"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton lien (TS, Discord, site) -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#0F0F28" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" Opacity="0.9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A1A45"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
